    <string name="block_properties_column_clearer_title">منظف العمود</string>
    <string name="block_properties_column_clearer_desc">يمسح العمود الذي يسقط فيه. ممتاز لتخفيف الضغط.</string>

    <string name="block_properties_row_clearer_title">منظف الصف</string>
