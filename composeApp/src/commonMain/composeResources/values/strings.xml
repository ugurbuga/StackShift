    <string name="block_properties_normal_title">Normal Block</string>
    <string name="block_properties_normal_desc">Standard filled cell. No special effect.</string>

    <string name="block_properties_column_clearer_title">Column Clearer</string>
    <string name="block_properties_column_clearer_desc">Clears the column it lands in. Great for lowering pressure.</string>

    <string name="block_properties_row_clearer_title">Row Clearer</string>
    <string name="block_properties_row_clearer_desc">Clears the row it lands in. Opens space quickly.</string>

    <string name="block_properties_ghost_title">Ghost</string>
    <string name="block_properties_ghost_desc">Can pass through other blocks. Useful for tight gaps.</string>

    <string name="block_properties_heavy_title">Heavy</string>
    <string name="block_properties_heavy_desc">Behaves more aggressively; has a stronger effect after landing.</string>

    <string name="block_properties_dot_desc">The small dot in the top-right shows that this block has a special effect. The dot and border color indicate the effect type.</string>
