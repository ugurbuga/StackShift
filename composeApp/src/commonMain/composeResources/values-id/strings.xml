    <string name="tutorial_stackshift_intro_title">Luncurkan piece dari dock bawah</string>
    <string name="tutorial_stackshift_intro_body">Piece aktifmu menunggu di bawah. Geser secara horizontal untuk menyelaraskan kolom, lalu lepaskan untuk meluncurkannya ke papan. Pratinjau piece berikutnya sengaja dibuat lebih samar agar fokus tetap pada piece aktif.</string>
    <string name="tutorial_stackshift_systems_title">Gunakan blok aksi saat papan mulai penuh</string>
    <string name="tutorial_stackshift_systems_body">Simpanan menukar piece saat ini, Jeda membekukan permainan, Properti blok menjelaskan simbol, dan Pengaturan mengubah tampilan. Tombol-tombol ini juga mengikuti gaya blok papan yang kamu pilih.</string>
    <string name="tutorial_stackshift_specials_title">Blok spesial bisa menyelamatkan permainan</string>
    <string name="tutorial_stackshift_specials_body">Beberapa piece memiliki efek spesial. Pelajari lencananya dan gunakan untuk menurunkan tekanan, membuka ruang, atau menembus tumpukan yang sulit.</string>
    <string name="tutorial_stackshift_ready_title">Kamu siap melanjutkan permainan ini</string>
    <string name="tutorial_stackshift_ready_body">Itu saja — rencanakan kolom berikutnya, perhatikan bilah launch, dan gunakan spesial di saat yang tepat. Kamu bisa membuka kembali tutorial ini kapan saja dari Pengaturan.</string>
    <string name="tutorial_stackshift_ready_tutorial_hint">Buka Tutorial kapan saja jika kamu ingin mengingat cepat kontrol dan ikon spesial.</string>
    <string name="tutorial_stackshift_ready_settings_hint">Buka Pengaturan untuk mengubah bahasa, tema, warna, dan gaya blok sebelum permainan berikutnya.</string>
    <string name="tutorial_intro_title">Seret salah satu dari tiga piece ke papan</string>
    <string name="tutorial_intro_body">Tiga bentuk menunggu di tray. Pilih yang kamu inginkan, seret ke sel kosong mana pun, dan lepaskan untuk menempatkannya tepat di tempat yang pas.</string>
    <string name="tutorial_systems_title">Pikirkan seluruh tray, bukan hanya satu langkah</string>
    <string name="tutorial_systems_body">Setelah menempatkan satu piece, tray yang tersisa tetap di layar. Saat ketiganya habis, trio baru akan muncul. Coba sisakan ruang yang cukup untuk setiap bentuk yang masih kamu miliki.</string>
    <string name="tutorial_specials_title">Baris dan kolom akan hilang saat terisi penuh</string>
    <string name="tutorial_specials_body">Di sini tidak ada piece spesial. Sebagai gantinya, penuhi satu baris penuh atau satu kolom penuh untuk membersihkannya. Jika keduanya selesai bersamaan, keduanya akan hilang sekaligus.</string>
    <string name="tutorial_ready_title">Kamu siap untuk alur puzzle blok yang baru</string>
    <string name="tutorial_ready_body">Terus perhatikan tray, siapkan pembersihan baris dan kolom, dan jangan sampai bentuk besar terjebak. Saat tak ada lagi dari tiga piece yang muat, permainan berakhir.</string>
    <string name="tutorial_ready_block_properties_hint">Buka Tutorial kapan saja jika kamu ingin meninjau kembali penempatan bebas dan pembersihan baris/kolom secara bersamaan.</string>
    <string name="tutorial_ready_settings_hint">Buka Pengaturan untuk mengubah bahasa, tema, warna, dan gaya blok sebelum permainan berikutnya.</string>
    <string name="tutorial_mergeshift_intro_title">Luncurkan piece untuk menggabungkan blok bernilai sama</string>
    <string name="tutorial_mergeshift_intro_body">Di MergeShift, piece diluncurkan dari dock. Saat sebuah blok mendarat di blok lain dengan nilai yang sama, keduanya akan bergabung menjadi nilai yang lebih tinggi. Terus gabungkan untuk membuka ruang dan mencapai skor yang lebih tinggi.</string>
    <string name="tutorial_mergeshift_systems_title">Rencanakan penggabunganmu untuk mencegah luapan</string>
    <string name="tutorial_mergeshift_systems_body">Setiap piece yang kamu luncurkan akan menambah tinggi kolom. Jika ada kolom yang mencapai puncak, permainan berakhir. Gunakan pratinjau untuk melihat di mana piece-mu akan mendarat dan dengan blok mana ia mungkin bergabung.</string>
    <string name="tutorial_mergeshift_specials_title">Gabungkan beberapa merger untuk combo yang lebih besar</string>
    <string name="tutorial_mergeshift_specials_body">Satu peluncuran dapat memicu reaksi berantai penggabungan. Combo ini memberikan lebih banyak poin dan membuka lebih banyak ruang di papan, membantumu bertahan dalam permainan lebih lama.</string>
    <string name="tutorial_mergeshift_ready_title">Kamu siap untuk MergeShift</string>
    <string name="tutorial_mergeshift_ready_body">Fokuslah untuk menjaga kolommu tetap rendah dan siapkan penggabungan bernilai tinggi. Semoga berhasil mencapai angka tertinggi!</string>
    <string name="settings_tutorial">Tutorial</string>
    <string name="settings_tutorial_body">Buka tutorial atau latihan terpandu kapan saja untuk meninjau penempatan bebas, pembersihan baris dan kolom, serta alur tray berisi tiga piece.</string>
    <string name="settings_tutorial_replay">Latihan</string>
    <string name="tutorial_ready_tutorial_hint">Buka Tutorial kapan saja jika kamu ingin meninjau kembali penempatan bebas dan pembersihan baris/kolom secara bersamaan.</string>
    <string name="interactive_onboarding_step_counter">Panduan %1$d / %2$d</string>
    <string name="interactive_onboarding_drag_title">Seret piece dari tray ke papan</string>
    <string name="interactive_onboarding_drag_body">Sentuh salah satu dari tiga bentuk di tray, pindahkan ke atas papan, lalu sejajarkan dengan sel yang disorot.</string>
    <string name="interactive_onboarding_drag_to_board">Seret piece yang disorot ke area target yang bercahaya.</string>
    <string name="interactive_onboarding_drag_ready">Bagus — lepaskan sekarang. Saat piece menempel ke sel yang disorot, panduan berikutnya akan terbuka otomatis.</string>
    <string name="interactive_onboarding_aim_hint">Lepaskan piece di dalam sel yang disorot untuk melanjutkan.</string>
    <string name="interactive_onboarding_target_locked">Pas sekali — tahan di sana lalu lepaskan untuk melanjutkan.</string>
    <string name="interactive_onboarding_waiting">Penempatan diterima. Momen terpandu berikutnya sedang disiapkan…</string>
    <string name="interactive_onboarding_line_clear_title">Penuhi satu baris untuk menghapusnya</string>
    <string name="interactive_onboarding_line_clear_body">Tempatkan bentuk ini di titik panduan agar barisnya penuh, menyala, lalu hilang.</string>
    <string name="interactive_onboarding_column_clearer_title">Penuhi satu kolom untuk menghapusnya</string>
    <string name="interactive_onboarding_column_clearer_body">Sekarang gunakan penempatan yang disorot untuk melengkapi satu kolom penuh dan membuka ruang vertikal.</string>
    <string name="interactive_onboarding_row_clearer_title">Baris membuka ruang horizontal</string>
    <string name="interactive_onboarding_row_clearer_body">Satu baris penuh akan langsung hilang. Arahkan ke sel yang disorot dan lihat bagaimana papan terbuka dari sisi ke sisi.</string>
    <string name="interactive_onboarding_ghost_title">Tray sama pentingnya dengan papan</string>
    <string name="interactive_onboarding_ghost_body">Sebelum menaruh satu bentuk, lihat juga dua piece lainnya. Permainan yang bagus datang dari menyisakan ruang untuk seluruh tray, bukan hanya langkah ini.</string>
    <string name="interactive_onboarding_heavy_title">Bersihkan dua arah sekaligus</string>
    <string name="interactive_onboarding_heavy_body">Beberapa penempatan bisa melengkapi satu baris dan satu kolom secara bersamaan. Gunakan titik panduan untuk memicu pembersihan ganda yang lebih besar.</string>

    <string name="interactive_onboarding_mergeshift_launch_title">Luncurkan piece pertamamu</string>
    <string name="interactive_onboarding_mergeshift_launch_body">Seret piece secara horizontal di bawah papan untuk membidik, lalu lepaskan untuk meluncurkannya ke dalam kolom.</string>
    <string name="interactive_onboarding_mergeshift_merge_vertical_title">Gabungkan nilai yang sama secara vertikal</string>
    <string name="interactive_onboarding_mergeshift_merge_vertical_body">Luncurkan piece ke dalam kolom yang sudah memiliki blok dengan nilai yang sama. Keduanya akan bergabung menjadi angka yang lebih tinggi!</string>
    <string name="interactive_onboarding_mergeshift_merge_horizontal_title">Gabungkan nilai yang sama secara horizontal</string>
    <string name="interactive_onboarding_mergeshift_merge_horizontal_body">Blok juga dapat bergabung dengan tetangganya di kiri atau kanan. Bidik tempat yang disorot untuk memicu penggabungan horizontal.</string>
    <string name="interactive_onboarding_mergeshift_merge_multi_title">Picu penggabungan ganda</string>
    <string name="interactive_onboarding_mergeshift_merge_multi_body">Satu penempatan dapat memicu penggabungan di berbagai arah (atas, kiri, kanan). Gunakan ini untuk membuka lebih banyak ruang dan mencetak skor besar!</string>

