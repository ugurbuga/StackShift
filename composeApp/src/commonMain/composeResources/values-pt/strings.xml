    <string name="block_properties_normal_title">Bloco normal</string>
    <string name="block_properties_normal_desc">Célula preenchida padrão. Sem efeito especial.</string>

    <string name="block_properties_column_clearer_title">Limpador de coluna</string>
    <string name="block_properties_column_clearer_desc">Limpa a coluna em que cai. Ótimo para reduzir a pressão.</string>

    <string name="block_properties_row_clearer_title">Limpador de linha</string>
