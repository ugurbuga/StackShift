    <string name="tutorial_finish">Iniciar jogo</string>
    <string name="tutorial_intro_title">Lance peças a partir do dock inferior</string>
    <string name="tutorial_intro_body">Sua peça ativa espera embaixo. Arraste-a horizontalmente para alinhar uma coluna e solte para lançá-la no tabuleiro. A prévia da próxima peça aparece mais suave de propósito para manter o foco na peça ativa.</string>
    <string name="tutorial_systems_title">Use os blocos de ação quando o tabuleiro apertar</string>
    <string name="tutorial_systems_body">Reserva troca a peça atual, Pausa congela a rodada, Propriedades do bloco explica os símbolos, e Configurações muda o visual. Esses botões também acompanham o estilo de bloco do tabuleiro que você escolheu.</string>
    <string name="tutorial_specials_title">Blocos especiais podem salvar uma partida</string>
    <string name="tutorial_specials_body">Algumas peças carregam efeitos especiais. Aprenda seus selos e use-os para aliviar a pressão, abrir espaço ou atravessar pilhas difíceis.</string>
    <string name="tutorial_ready_title">Você está pronto para continuar esta partida</string>
    <string name="tutorial_ready_body">É isso — planeje a próxima coluna, acompanhe a barra de lançamento e use os especiais na hora certa. Você pode abrir este tutorial novamente a qualquer momento em Configurações.</string>
    <string name="tutorial_ready_block_properties_hint">Abra Propriedades do bloco sempre que quiser relembrar rapidamente o que cada ícone especial faz.</string>
    <string name="tutorial_ready_settings_hint">Abra Configurações para mudar idioma, tema, cores e estilo dos blocos antes da sua próxima partida.</string>
    <string name="settings_tutorial">Tutorial</string>
    <string name="settings_tutorial_body">Abra o tutorial ou a prática guiada a qualquer momento para rever os controles, os blocos especiais e o fluxo de lançamento.</string>
    <string name="settings_tutorial_replay">Prática</string>
    <string name="tutorial_ready_tutorial_hint">Abra o Tutorial sempre que quiser relembrar rapidamente os controles e os ícones especiais.</string>
    <string name="interactive_onboarding_step_counter">Guia %1$d / %2$d</string>
    <string name="interactive_onboarding_drag_title">Arraste a peça da bandeja</string>
    <string name="interactive_onboarding_drag_body">Comece tocando na peça ativa na bandeja inferior e deslizando para a esquerda ou para a direita. Solte quando ela estiver alinhada com uma coluna aberta.</string>
    <string name="interactive_onboarding_drag_to_board">Arraste a peça ativa para os lados e alinhe-a com a faixa de lançamento destacada.</string>
    <string name="interactive_onboarding_drag_ready">Ótimo — solte agora. Quando a peça cair dentro da caixa destacada, o próximo guia será aberto automaticamente.</string>
    <string name="interactive_onboarding_aim_hint">Solte a peça dentro da caixa destacada para continuar.</string>
    <string name="interactive_onboarding_target_locked">Perfeito — mantenha-a aí e solte para continuar.</string>
    <string name="interactive_onboarding_waiting">Posicionamento aceito. Preparando o próximo momento guiado…</string>
    <string name="interactive_onboarding_line_clear_title">Complete uma linha para limpá-la</string>
    <string name="interactive_onboarding_line_clear_body">Peças normais também abrem espaço quando completam uma linha inteira. Solte esta peça na coluna guiada e veja a linha se completar, brilhar e desaparecer.</string>
    <string name="interactive_onboarding_column_clearer_title">Limpador de coluna limpa uma coluna inteira</string>
    <string name="interactive_onboarding_column_clearer_body">Esta peça especial limpa a coluna em que aterrissa. Siga a coluna destacada para sentir imediatamente como ela alivia a pressão.</string>
    <string name="interactive_onboarding_row_clearer_title">Limpador de linha abre espaço horizontal</string>
    <string name="interactive_onboarding_row_clearer_body">Esta peça limpa a linha inteira que toca. Mire na coluna guiada e veja a linha se abrir por todo o tabuleiro.</string>
    <string name="interactive_onboarding_ghost_title">Fantasma atravessa pilhas apertadas</string>
    <string name="interactive_onboarding_ghost_body">Blocos Fantasma podem atravessar células existentes. Solte-o na coluna marcada para ver como ele alcança espaços que peças normais não alcançam.</string>
    <string name="interactive_onboarding_heavy_title">Pesado altera o tabuleiro de forma agressiva</string>
    <string name="interactive_onboarding_heavy_body">Blocos Pesados remodelam a área após pousarem. Faça a queda guiada e depois continue a partida normalmente a partir daí.</string>
</resources>
