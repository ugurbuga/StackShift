    <string name="interactive_onboarding_step_counter">引导 %1$d / %2$d</string>
    <string name="interactive_onboarding_drag_title">把托盘中的方块拖到棋盘上</string>
    <string name="interactive_onboarding_drag_body">点按托盘中的任意一个形状，把它移动到棋盘上，并与高亮单元格对齐。</string>
    <string name="interactive_onboarding_drag_to_board">把高亮的方块拖到发光的目标区域中。</string>
    <string name="interactive_onboarding_drag_ready">很好——现在松手。等它吸附到高亮单元格后，下一步引导会自动打开。</string>
    <string name="interactive_onboarding_aim_hint">把方块放进高亮单元格内以继续。</string>
    <string name="interactive_onboarding_target_locked">很好——保持在这里，然后松手继续。</string>
    <string name="interactive_onboarding_waiting">放置已接受，正在准备下一步引导…</string>
    <string name="interactive_onboarding_line_clear_title">填满一整行并清除它</string>
    <string name="interactive_onboarding_line_clear_body">把这个形状放到引导位置，让这一行填满、闪光并消失。</string>
    <string name="interactive_onboarding_column_clearer_title">填满一整列并清除它</string>
    <string name="interactive_onboarding_column_clearer_body">现在使用高亮的放置位置补满整列，腾出纵向空间。</string>
    <string name="interactive_onboarding_row_clearer_title">整行可以打开横向空间</string>
    <string name="interactive_onboarding_row_clearer_body">一整行填满后会立刻清除。对准高亮单元格，看看棋盘如何横向打开。</string>
    <string name="interactive_onboarding_ghost_title">托盘和棋盘同样重要</string>
    <string name="interactive_onboarding_ghost_body">放置当前形状前，也看看另外两块。好的局面来自为整组托盘留空间，而不只是当前这一步。</string>
    <string name="interactive_onboarding_heavy_title">同时清除两个方向</string>
    <string name="interactive_onboarding_heavy_body">有些放置会同时完成一行和一列。用这个引导位置触发一次更大的双重清除。</string>

    <string name="interactive_onboarding_mergeshift_launch_title">发射你的第一个方块</string>
    <string name="interactive_onboarding_mergeshift_launch_body">在棋盘下方水平拖动方块进行瞄准，然后松手将其发射到一列中。</string>
    <string name="interactive_onboarding_mergeshift_merge_vertical_title">垂直合并相同数值</string>
    <string name="interactive_onboarding_mergeshift_merge_vertical_body">将方块发射到已经包含相同数值方块的列中。它们将合并成一个更大的数字！</string>
    <string name="interactive_onboarding_mergeshift_merge_horizontal_title">水平合并相同数值</string>
    <string name="interactive_onboarding_mergeshift_merge_horizontal_body">方块也可以与其左侧或右侧的相邻方块合并。瞄准高亮位置以触发水平合并。</string>
    <string name="interactive_onboarding_mergeshift_merge_multi_title">触发多次合并</string>
    <string name="interactive_onboarding_mergeshift_merge_multi_body">单次放置可以触发多个方向（上方、左侧、右侧）的合并。利用这一点腾出更多空间并获得高分！</string>

